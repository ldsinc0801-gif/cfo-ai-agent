# freee API認証情報
FREEE_CLIENT_ID=your_client_id
FREEE_CLIENT_SECRET=your_client_secret
FREEE_REDIRECT_URI=http://localhost:3000/callback
FREEE_ACCESS_TOKEN=your_access_token
FREEE_REFRESH_TOKEN=your_refresh_token

# freee 事業所ID（省略時は事業所一覧から選択）
FREEE_COMPANY_ID=

# AI設定
OPENAI_API_KEY=your_openai_api_key
CHAT_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
AI_PROVIDER=template

# Google連携（ログイン + Tasks/Gmail）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/login/google/callback

# Supabase（データベース）
SUPABASE_URL=
SUPABASE_ANON_KEY=

# セッション（未設定時は自動生成）
SESSION_SECRET=

# 出力設定
OUTPUT_DIR=./output
OUTPUT_FORMAT=both
