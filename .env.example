# freee API認証情報
FREEE_CLIENT_ID=your_client_id
FREEE_CLIENT_SECRET=your_client_secret
FREEE_REDIRECT_URI=http://localhost:3000/callback
FREEE_ACCESS_TOKEN=your_access_token
FREEE_REFRESH_TOKEN=your_refresh_token

# freee 事業所ID（省略時は事業所一覧から選択）
FREEE_COMPANY_ID=

# AI設定
OPENAI_API_KEY=your_openai_api_key
CHAT_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
AI_PROVIDER=template

# Google連携（ログイン + Tasks/Gmail）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:3000/auth/login/google/callback

# Supabase（データベース）
SUPABASE_URL=
SUPABASE_ANON_KEY=
# 本番運用では service_role キーを使用（RLSバイパス、Phase 9 で切替済み）
SUPABASE_SERVICE_ROLE_KEY=

# Postgres 直接接続（任意）
# 設定するとセッションが Supabase Postgres に保存され、サーバー再起動でも維持される。
# 未設定の場合は MemoryStore で動作（再起動でセッションリセット、ユーザー数が少ない間はOK）。
# Supabase の Project Settings > Database > Connection string > URI（Transaction mode 推奨）
DATABASE_URL=

# セッション（未設定時は自動生成。本番では必須）
SESSION_SECRET=

# 出力設定
OUTPUT_DIR=./output
OUTPUT_FORMAT=both
